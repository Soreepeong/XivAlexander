        MENUITEM "抧堟丗杒暷(&2)",                   ID_RESTART_REGION_NORTH_AMERICA
        MENUITEM "抧堟丗墷廈(&3)",                   ID_RESTART_REGION_EUROPE
        MENUITEM SEPARATOR
