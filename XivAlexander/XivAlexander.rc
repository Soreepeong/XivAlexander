        MENUITEM SEPARATOR
        MENUITEM "Use &Word Wrap\tCtrl+R",      ID_VIEW_USEWORDWRAP
        MENUITEM "Use &Monospaced Font\tCtrl+M", ID_VIEW_USEMONOSPACEDFONT
    END
END

