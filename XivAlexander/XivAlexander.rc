/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_TRAY_MENU MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "(Current Process Information)", ID_FILE_CURRENTINFO
        MENUITEM SEPARATOR
        MENUITEM "Show &Control Window\tCtrl+(Alt+)W", ID_FILE_SHOWCONTROLWINDOW
        MENUITEM "Show &Logging Window\t(Ctrl+Alt+)L", ID_FILE_SHOWLOGGINGWINDOW
        MENUITEM "Check for U&pdates\tCtrl+(Alt+)U", ID_FILE_CHECKFORUPDATES
        MENUITEM "&Unload XivAlexander\tCtrl+(Alt+)Q", ID_FILE_UNLOADXIVALEXANDER
        MENUITEM SEPARATOR
        MENUITEM "Force E&xit Game\tCtrl+Shift+Q", ID_FILE_FORCEEXITGAME
    END
    POPUP "&Restart"
    BEGIN
        MENUITEM "&Restart Using Choices Below\tCtrl+Shift+R", ID_RESTART_RESTART
        MENUITEM SEPARATOR
        MENUITEM "Use &DirectX 11\t(Ctrl+Shift+)D", ID_RESTART_USEDIRECTX11
        MENUITEM "Use &XivAlexander\t(Ctrl+Shift+)X", ID_RESTART_USEXIVALEXANDER
        MENUITEM "Use &Parameter Obfuscation\t(Ctrl+Shift+)P", ID_RESTART_USEPARAMETEROBFUSCATION
        MENUITEM "Use Elevation (Run as &Administrator)\t(Ctrl+Shift+)A", ID_RESTART_USEELEVATION
        MENUITEM SEPARATOR
        MENUITEM "Language: &Japanese",         ID_RESTART_LANGUAGE_JAPANESE
        MENUITEM "Language: &English",          ID_RESTART_LANGUAGE_ENGLISH
        MENUITEM "Language: &German",           ID_RESTART_LANGUAGE_GERMAN
        MENUITEM "Language: &French",           ID_RESTART_LANGUAGE_FRENCH
        MENUITEM "Language: &Chinese(Simplified)", ID_RESTART_LANGUAGE_SIMPLIFIEDCHINESE
        MENUITEM "Language: &Korean",           ID_RESTART_LANGUAGE_KOREAN
        MENUITEM SEPARATOR
        MENUITEM "Region: Japan (&1)",          ID_RESTART_REGION_JAPAN
        MENUITEM "Region: North America (&2)",  ID_RESTART_REGION_NORTH_AMERICA
        MENUITEM "Region: Europe (&3)",         ID_RESTART_REGION_EUROPE
        MENUITEM SEPARATOR
        MENUITEM "Remember &Language Settings", ID_RESTART_LANGUAGE_REMEMBER, CHECKED
        MENUITEM "Remember Region &Settings",   ID_RESTART_REGION_REMEMBER, CHECKED
    END
    POPUP "&Network"
    BEGIN
        POPUP "Latency and Timing &Helper"
        BEGIN
            MENUITEM "&Enable\t(Ctrl+Shift+)H",     ID_NETWORK_HIGHLATENCYMITIGATION_ENABLE
            MENUITEM SEPARATOR
            MENUITEM "Mode &1: Subtract Latency",   ID_NETWORK_HIGHLATENCYMITIGATION_MODE_1
            MENUITEM "Mode &2: Simulate RTT ({}us)", ID_NETWORK_HIGHLATENCYMITIGATION_MODE_2
            MENUITEM "Mode &3: Simulate Normalized RTT and Latency", ID_NETWORK_HIGHLATENCYMITIGATION_MODE_3
            MENUITEM SEPARATOR
            MENUITEM "Use &Logging\tCtrl+(Alt+)L",  ID_NETWORK_HIGHLATENCYMITIGATION_USELOGGING
            MENUITEM "&Preview Mode (Dry Run)\tCtrl+(Alt+)P", ID_NETWORK_HIGHLATENCYMITIGATION_PREVIEWMODE
        END
        MENUITEM SEPARATOR
        MENUITEM "Use IPC Type &Finder\t(Ctrl+Shift+)F", ID_NETWORK_USEIPCTYPEFINDER
        MENUITEM "Log All &IPC Message \t(Ctrl+Shift+)M", ID_NETWORK_USEALLIPCMESSAGELOGGER
        MENUITEM SEPARATOR
        MENUITEM "&Reduce Packet Delay\t(Ctrl+Shift+)F1", ID_NETWORK_REDUCEPACKETDELAY
        MENUITEM "R&elease All Connections\t(Ctrl+Shift+)F2", ID_NETWORK_RELEASEALLCONNECTIONS
        MENUITEM "Re&set All Connections\t(Ctrl+Shift+)F3", ID_NETWORK_RESETALLCONNECTIONS
        POPUP "&Troubleshooting"
        BEGIN
            MENUITEM "Take Over &Loopback Addresses (127.0.0.0/8)\t(Ctrl+Shift+)1", ID_NETWORK_TROUBLESHOOTREMOTEADDRESSES_TAKEOVERLOOPBACKADDRESSES
            MENUITEM "Take Over &Private Addresses (10.0.0.0/8, 169.254.0.0/16, 172.16.0.0/12, 192.168.0.0/24)\t(Ctrl+Shift+)2", ID_NETWORK_TROUBLESHOOTREMOTEADDRESSES_TAKEOVERPRIVATEADDRESSES
            MENUITEM "Take Over &All Addresses (0.0.0.0/0)\t(Ctrl+Shift+)3", ID_NETWORK_TROUBLESHOOTREMOTEADDRESSES_TAKEOVERALLADDRESSES
            MENUITEM "Take Over All P&orts\t(Ctrl+Shift+)4", ID_NETWORK_TROUBLESHOOTREMOTEADDRESSES_TAKEOVERALLPORTS
        END
    END
    POPUP "&Modding"
    BEGIN
        MENUITEM "&Enable",                     ID_MODDING_ENABLE
        MENUITEM SEPARATOR
        POPUP "&TexTools ModPacks"
        BEGIN
            POPUP "(template entry to be inserted at bottom)"
            BEGIN
                MENUITEM "&Enable",                     ID_MODDING_TTMP_ENTRY_ENABLE, CHECKED
                MENUITEM "&Delete",                     ID_MODDING_TTMP_ENTRY_DELETE
                MENUITEM SEPARATOR
                MENUITEM "Requires restart",            ID_MODDING_TTMP_ENTRY_REQUIRESRESTART, INACTIVE
                MENUITEM "&Show Description",           ID_MODDING_TTMP_ENTRY_SHOWDESCRIPTION
                MENUITEM SEPARATOR
            END
            MENUITEM "(No installed ModPacks found)", ID_MODDING_TTMP_NOENTRY, INACTIVE
            MENUITEM "(Not ready)",                 ID_MODDING_TTMP_NOTREADY, INACTIVE
            MENUITEM SEPARATOR
            MENUITEM "&Flatten Folder Display",     ID_MODDING_TTMP_FLATTENSUBDIRECTORYDISPLAY
            MENUITEM "Use Folder &Toggling on Flattened View", ID_MODDING_TTMP_USESUBDIRECTORYTOGGLINGONFLATTENEDVIEW
            MENUITEM "Show Dedicated &Menu",        ID_MODDING_TTMP_SHOWDEDICATEDMENU
            MENUITEM SEPARATOR
            MENUITEM "&Enable All",                 ID_MODDING_TTMP_ENABLEALL
            MENUITEM "&Disable All",                ID_MODDING_TTMP_DISABLEALL
            MENUITEM "De&lete All",                 ID_MODDING_TTMP_REMOVEALL
            MENUITEM SEPARATOR
            MENUITEM "&Import",                     ID_MODDING_TTMP_IMPORT
            MENUITEM "&Open Directory",             ID_MODDING_TTMP_OPENDIRECTORY
            MENUITEM "&Refresh",                    ID_MODDING_TTMP_REFRESH
        END
        MENUITEM "Open &Replacement File Entries Directory", ID_MODDING_OPENREPLACEMENTFILEENTRIESDIRECTORY
        MENUITEM "Exp&ort to TTMPL/TTMPD Files", ID_MODDING_EXPORTTOTTMP
        MENUITEM SEPARATOR
        MENUITEM "Log All F&ile Access",        ID_MODDING_LOGALLFILEACCESS
        POPUP "Mute &Voice"
        BEGIN
            MENUITEM "&Battle",                     ID_MODDING_MUTEVOICE_BATTLE
            MENUITEM "&CM (Probably environmental voices)", ID_MODDING_MUTEVOICE_CM
            MENUITEM "&Emote",                      ID_MODDING_MUTEVOICE_EMOTE
            MENUITEM "NPC &Dialogue During Battle", ID_MODDING_MUTEVOICE_LINE
        END
        MENUITEM SEPARATOR
        MENUITEM "Anything here will not be fully applied until game restart.", ID_MODDING_ANYTHINGBELOWHEREWILLBEAPPLIEDONRESTART, INACTIVE
    END
    POPUP "&TTMP"
    BEGIN
        MENUITEM SEPARATOR
    END
    POPUP "&Configure"
    BEGIN
        MENUITEM "Edit &Runtime Configuration\t(Ctrl+Alt+)R", ID_CONFIGURE_EDITRUNTIMECONFIGURATION
        MENUITEM "Edit &Opcode Configuration\t(Ctrl+Alt+)O", ID_CONFIGURE_EDITOPCODECONFIGURATION
        MENUITEM "Check for Opcode &Updates",   ID_CONFIGURE_CHECKFORUPDATEDOPCODES
        MENUITEM "Check for Opcode Updates on S&tartup", ID_CONFIGURE_CHECKFORUPDATEDOPCODESONSTARTUP
        MENUITEM SEPARATOR
        POPUP "Game Fi&x"
        BEGIN
            MENUITEM "(None available)",            ID_CONFIGURE_GAMEFIX_EMPTY, INACTIVE
        END
        MENUITEM SEPARATOR
        MENUITEM "Force the Game to Use More &CPU Time", ID_CONFIGURE_USEMORECPUTIME
        MENUITEM "Lock &Framerate ",            ID_CONFIGURE_LOCKFRAMERATE
        MENUITEM "Synchronize &Processing to Cooldowns and Animation Locks", ID_CONFIGURE_SYNCHRONIZEPROCESSING
        MENUITEM "Add Process &ID to Game Window Title", 40537
        MENUITEM SEPARATOR
        MENUITEM "Use &System Default Language", ID_CONFIGURE_LANGUAGE_SYSTEMDEFAULT
        MENUITEM "Language: &English",          ID_CONFIGURE_LANGUAGE_ENGLISH
        MENUITEM "Language: &Korean",           ID_CONFIGURE_LANGUAGE_KOREAN
        MENUITEM "Language: &Japanese",         ID_CONFIGURE_LANGUAGE_JAPANESE
        MENUITEM SEPARATOR
        MENUITEM "Open Configuration &Directory", ID_CONFIGURE_OPENCONFIGURATIONDIRECTORY
        MENUITEM "Reload (&Z)\t(Ctrl+Shift+)F5", ID_CONFIGURE_RELOAD
    END
    POPUP "&View"
    BEGIN
        MENUITEM "Always on &Top\tCtrl+T",      ID_VIEW_ALWAYSONTOP
        MENUITEM "Always on Top (Game &Window)\tCtrl+Shift+T", ID_VIEW_ALWAYSONTOPGAME
        MENUITEM SEPARATOR
        MENUITEM "&Hide on Minimize",           ID_VIEW_HIDEONMINIMIZE
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "Open Help &Webpage",          ID_HELP_OPENHELPWEBPAGE
        MENUITEM SEPARATOR
        MENUITEM "Open &Homepage",              ID_HELP_OPENHOMEPAGE
    END
END

IDR_LOG_MENU MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Save\tCtrl+S",               ID_FILE_SAVE
        MENUITEM "&Empty\tCtrl+E",              ID_FILE_CLEAR
        MENUITEM SEPARATOR
        MENUITEM "Close (&W)\tCtrl+W",          ID_FILE_CLOSE
