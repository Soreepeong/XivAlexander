IDR_TRAY_MENU MENU
BEGIN
    POPUP "颇老(&F)"
    BEGIN
        MENUITEM "(Current Process Information)", ID_FILE_CURRENTINFO
        MENUITEM SEPARATOR
        MENUITEM "包府 芒 焊捞扁(&C)\tCtrl+(Alt+)W",  ID_FILE_SHOWCONTROLWINDOW
        MENUITEM "肺弊 芒 焊捞扁(&L)\t(Ctrl+Alt+)L",  ID_FILE_SHOWLOGGINGWINDOW
        MENUITEM "诀单捞飘 犬牢(&P)\tCtrl+(Alt+)U",   ID_FILE_CHECKFORUPDATES
        MENUITEM "XivAlexander 辆丰(&U)\tCtrl+(Alt+)Q", ID_FILE_UNLOADXIVALEXANDER
        MENUITEM SEPARATOR
        MENUITEM "霸烙 碍力 辆丰(&X)\tCtrl+Shift+Q",  ID_FILE_FORCEEXITGAME
    END
    POPUP "犁矫累(&R)"
    BEGIN
        MENUITEM "酒贰 汲沥阑 馆康秦 犁矫累窍扁(&R)\tCtrl+Shift+R", ID_RESTART_RESTART
        MENUITEM SEPARATOR
        MENUITEM "DirectX 11 荤侩(&I)\t(Ctrl+Shift+)D", ID_RESTART_USEDIRECTX11
        MENUITEM "XivAlexander 荤侩(&X)\t(Ctrl+Shift+)X", ID_RESTART_USEXIVALEXANDER
        MENUITEM "疙飞临 抄刀拳 荤侩(&P)\t(Ctrl+Shift+)P", ID_RESTART_USEPARAMETEROBFUSCATION
        MENUITEM "包府磊 鼻茄栏肺 角青(&A)\t(Ctrl+Shift+)A", ID_RESTART_USEELEVATION
        MENUITEM SEPARATOR
        MENUITEM "攫绢: 老夯绢(&J)",                 ID_RESTART_LANGUAGE_JAPANESE
        MENUITEM "攫绢: 康绢(&E)",                  ID_RESTART_LANGUAGE_ENGLISH
        MENUITEM "攫绢: 刀老绢(&D)",                 ID_RESTART_LANGUAGE_GERMAN
        MENUITEM "攫绢: 橇尔胶绢(&F)",                ID_RESTART_LANGUAGE_FRENCH
        MENUITEM "攫绢: 吝惫绢(埃眉)(&C)",             ID_RESTART_LANGUAGE_SIMPLIFIEDCHINESE
        MENUITEM "攫绢: 茄惫绢(&K)",                 ID_RESTART_LANGUAGE_KOREAN
        MENUITEM SEPARATOR
        MENUITEM "瘤开: 老夯(&1)",                  ID_RESTART_REGION_JAPAN
        MENUITEM "瘤开: 合固(&2)",                  ID_RESTART_REGION_NORTH_AMERICA
        MENUITEM "瘤开: 蜡反(&3)",                  ID_RESTART_REGION_EUROPE
        MENUITEM SEPARATOR
        MENUITEM "攫绢 汲沥 扁撅(&L)",                ID_RESTART_LANGUAGE_REMEMBER, CHECKED
        MENUITEM "瘤开 汲沥 扁撅(&S)",                ID_RESTART_REGION_REMEMBER, CHECKED
    END
    POPUP "匙飘况农(&N)"
    BEGIN
        POPUP "瘤楷 棺 鸥捞怪 档快固(&H)"
        BEGIN
            MENUITEM "荤侩(&E)\t(Ctrl+Shift+)H",      ID_NETWORK_HIGHLATENCYMITIGATION_ENABLE
            MENUITEM SEPARATOR
            MENUITEM "葛靛 &1: 瘤楷 矫埃父怒 促澜 扁贱 矫傈 啊瓷 矫阿 菊寸扁扁", ID_NETWORK_HIGHLATENCYMITIGATION_MODE_1
            MENUITEM "葛靛 &2: 辑滚 览翠 矫埃阑 {}us肺 绊沥",   ID_NETWORK_HIGHLATENCYMITIGATION_MODE_2
            MENUITEM "葛靛 &3: 辑滚 览翠 棺 瘤楷 矫埃 焊沥",     ID_NETWORK_HIGHLATENCYMITIGATION_MODE_3
            MENUITEM SEPARATOR
            MENUITEM "肺弊 荤侩(&L)\tCtrl+(Alt+)L",     ID_NETWORK_HIGHLATENCYMITIGATION_USELOGGING
            MENUITEM "葛狼 累悼 (肺弊俊辑 固府 焊扁)(&P)\tCtrl+(Alt+)P", ID_NETWORK_HIGHLATENCYMITIGATION_PREVIEWMODE
        END
        MENUITEM SEPARATOR
        MENUITEM "IPC 八祸 档快固 荤侩(&F)\t(Ctrl+Shift+)F", ID_NETWORK_USEIPCTYPEFINDER
        MENUITEM "葛电 IPC 皋矫瘤 肺弊 荤侩(&I)\t(Ctrl+Shift+)M", ID_NETWORK_USEALLIPCMESSAGELOGGER
        MENUITEM SEPARATOR
        MENUITEM "菩哦 掉饭捞 皑家(&R)\t(Ctrl+Shift+)F1", ID_NETWORK_REDUCEPACKETDELAY
        MENUITEM "葛电 楷搬 贸府 秦力窍扁(&E)\t(Ctrl+Shift+)F2", ID_NETWORK_RELEASEALLCONNECTIONS
        MENUITEM "葛电 立加 碍力 秦力窍扁(&S)\t(Ctrl+Shift+)F3", ID_NETWORK_RESETALLCONNECTIONS
        POPUP "巩力 秦搬(&T)"
        BEGIN
            MENUITEM "风橇归 林家 贸府(&L) (127.0.0.0/8)\t(Ctrl+Shift+)1", ID_NETWORK_TROUBLESHOOTREMOTEADDRESSES_TAKEOVERLOOPBACKADDRESSES
            MENUITEM "荤汲 林家 贸府(&P) (10.0.0.0/8, 169.254.0.0/16, 172.16.0.0/12, 192.168.0.0/24)\t(Ctrl+Shift+)2", ID_NETWORK_TROUBLESHOOTREMOTEADDRESSES_TAKEOVERPRIVATEADDRESSES
            MENUITEM "葛电 林家 贸府(&A) (0.0.0.0/0)\t(Ctrl+Shift+)3", ID_NETWORK_TROUBLESHOOTREMOTEADDRESSES_TAKEOVERALLADDRESSES
            MENUITEM "葛电 器飘 贸府(&O)\t(Ctrl+Shift+)4", ID_NETWORK_TROUBLESHOOTREMOTEADDRESSES_TAKEOVERALLPORTS
        END
    END
    POPUP "葛爹(&M)"
    BEGIN
        MENUITEM "荤侩(&E)",                      ID_MODDING_ENABLE
        MENUITEM SEPARATOR
        MENUITEM "葛电 颇老 立辟 扁废窍扁(&I)",           ID_MODDING_LOGALLFILEACCESS
        MENUITEM "背眉 颇老 弃歹 凯扁(&R)",             ID_MODDING_OPENREPLACEMENTFILEENTRIESDIRECTORY
        MENUITEM "TTMPL/TTMPD颇老肺 郴焊郴扁(&O)",     ID_MODDING_EXPORTTOTTMP
        MENUITEM SEPARATOR
        POPUP "TexTools 葛靛蒲(&T)"
        BEGIN
            POPUP "(template entry to be inserted at bottom)"
            BEGIN
                MENUITEM "荤侩窃(&E)",                     ID_MODDING_TTMP_ENTRY_ENABLE, CHECKED
                MENUITEM "力芭(&D)",                      ID_MODDING_TTMP_ENTRY_DELETE
                MENUITEM SEPARATOR
                MENUITEM "犁矫累 鞘夸",                      ID_MODDING_TTMP_ENTRY_REQUIRESRESTART, INACTIVE
                MENUITEM "汲疙 焊扁(&S)",                   ID_MODDING_TTMP_ENTRY_SHOWDESCRIPTION
                MENUITEM SEPARATOR
            END
            MENUITEM "(汲摹等 葛靛蒲 绝澜 )",               ID_MODDING_TTMP_NOENTRY, INACTIVE
            MENUITEM "(葛爹 扁瓷 霖厚登瘤 臼澜)",             ID_MODDING_TTMP_NOTREADY, INACTIVE
            MENUITEM SEPARATOR
            MENUITEM "老瞒盔栏肺 弃歹 钎矫(&F)",             ID_MODDING_TTMP_FLATTENSUBDIRECTORYDISPLAY
            MENUITEM "老瞒盔栏肺 弃歹 钎矫 矫 弃歹 劝己拳 力绢 荤侩(&T)", ID_MODDING_TTMP_USESUBDIRECTORYTOGGLINGONFLATTENEDVIEW
            MENUITEM "傈侩 皋春 焊捞扁(&M)",               ID_MODDING_TTMP_SHOWDEDICATEDMENU
            MENUITEM SEPARATOR
            MENUITEM "葛滴 劝己拳(&E)",                  ID_MODDING_TTMP_ENABLEALL
            MENUITEM "葛滴 厚劝己拳(&D)",                 ID_MODDING_TTMP_DISABLEALL
            MENUITEM SEPARATOR
            MENUITEM "阂矾坷扁(&I)",                    ID_MODDING_TTMP_IMPORT
            MENUITEM "弃歹 凯扁(&O)",                   ID_MODDING_TTMP_OPENDIRECTORY
            MENUITEM "葛滴 力芭(&L)",                   ID_MODDING_TTMP_REMOVEALL
            MENUITEM "格废 促矫 阂矾坷扁(&R)",              ID_MODDING_TTMP_REFRESH
        END
        POPUP "格家府 盒幅 澜家芭(&V)"
        BEGIN
            MENUITEM "傈捧(&B)",                      ID_MODDING_MUTEVOICE_BATTLE
            MENUITEM "CM(券版 加 格家府肺 眠螟)(&C)",        ID_MODDING_MUTEVOICE_CM
            MENUITEM "皑沥 钎泅(&E)",                   ID_MODDING_MUTEVOICE_EMOTE
            MENUITEM "傈捧 吝 NPC 措荤(&D)",             ID_MODDING_MUTEVOICE_LINE
        END
        MENUITEM SEPARATOR
        MENUITEM "霸烙 犁矫累鳖瘤 函版 荤亲捞 馆康登瘤 臼阑 荐档 乐嚼聪促.", ID_MODDING_ANYTHINGBELOWHEREWILLBEAPPLIEDONRESTART, INACTIVE
    END
    POPUP "TTMP(&T)"
    BEGIN
        MENUITEM SEPARATOR
    END
    POPUP "汲沥(&C)"
    BEGIN
        MENUITEM "繁鸥烙(橇肺弊伐) 汲沥 函版(&R)\t(Ctrl+Alt+)R", ID_CONFIGURE_EDITRUNTIMECONFIGURATION
        MENUITEM "可内靛 汲沥 函版(&O)\t(Ctrl+Alt+)O", ID_CONFIGURE_EDITOPCODECONFIGURATION
        MENUITEM "可内靛 诀单捞飘 犬牢窍扁(&U)",           ID_CONFIGURE_CHECKFORUPDATEDOPCODES
        MENUITEM "橇肺弊伐 矫累 矫 磊悼栏肺 可内靛 诀单捞飘 犬牢(&T)", ID_CONFIGURE_CHECKFORUPDATEDOPCODESONSTARTUP
        MENUITEM SEPARATOR
        POPUP "霸烙 滚弊 荐沥(&X)"
        BEGIN
            MENUITEM "(荐沥 啊瓷茄 滚弊 绝澜)",              ID_CONFIGURE_GAMEFIX_EMPTY, INACTIVE
        END
        MENUITEM SEPARATOR
        MENUITEM "霸烙捞 啊瓷茄 父怒 CPU甫 静档废 父甸扁(&C)", ID_CONFIGURE_USEMORECPUTIME
        MENUITEM "FPS 绊沥(&F)",                  ID_CONFIGURE_LOCKFRAMERATE
        MENUITEM "犁荤侩 措扁 矫埃 棺 局聪皋捞记 矫埃俊 霸烙 贸府甫 悼扁拳窍扁(&P)", ID_CONFIGURE_SYNCHRONIZEPROCESSING
        MENUITEM "霸烙 芒 力格俊 PID 钎矫(&I)",         ID_CONFIGURE_ADDPIDTOGAMEWINDOWTITLE
        MENUITEM SEPARATOR
        MENUITEM "矫胶袍 扁夯 攫绢 荤侩(&S)",            ID_CONFIGURE_LANGUAGE_SYSTEMDEFAULT
        MENUITEM "攫绢: 康绢(&E)",                  ID_CONFIGURE_LANGUAGE_ENGLISH
        MENUITEM "攫绢: 茄惫绢(&K)",                 ID_CONFIGURE_LANGUAGE_KOREAN
        MENUITEM "攫绢: 老夯绢(&J)",                 ID_CONFIGURE_LANGUAGE_JAPANESE
        MENUITEM SEPARATOR
        MENUITEM "汲沥蔼 历厘 弃歹 凯扁(&D)",            ID_CONFIGURE_OPENCONFIGURATIONDIRECTORY
        MENUITEM "汲沥 促矫 阂矾坷扁(&Z)\t(Ctrl+Shift+)F5", ID_CONFIGURE_RELOAD
    END
    POPUP "焊扁(&V)"
    BEGIN
        MENUITEM "亲惑 困俊 钎矫(&T)\tCtrl+T",        ID_VIEW_ALWAYSONTOP
        MENUITEM "霸烙阑 亲惑 困俊 钎矫(&W)\tCtrl+Shift+T", ID_VIEW_ALWAYSONTOPGAME
        MENUITEM SEPARATOR
        MENUITEM "弥家拳 矫 见辫(&H)",                ID_VIEW_HIDEONMINIMIZE
    END
    POPUP "档框富(&H)"
    BEGIN
        MENUITEM "档框富 昆其捞瘤 钎矫(&W)",             ID_HELP_OPENHELPWEBPAGE
        MENUITEM SEPARATOR
        MENUITEM "权其捞瘤 钎矫(&H)",                 ID_HELP_OPENHOMEPAGE
    END
END

