            MENUITEM "偡傋偰傪柍岠壔(&D)",                 ID_MODDING_TTMP_DISABLEALL
            MENUITEM SEPARATOR
            MENUITEM "僀儞億乕僩(&I)",                   ID_MODDING_TTMP_IMPORT
            MENUITEM "僼僅儖僟乕傪奐偗傞(&O)",               ID_MODDING_TTMP_OPENDIRECTORY
            MENUITEM "偡傋偰偺MOD僷僢僋傪嶍彍(&L)",           ID_MODDING_TTMP_REMOVEALL
            MENUITEM "嵞撉傒崬傒(&R)",                   ID_MODDING_TTMP_REFRESH
        END
        MENUITEM "抲偒姺偊僼傽僀儖偺僼僅儖僟乕傪奐偗傞(&R)",      ID_MODDING_OPENREPLACEMENTFILEENTRIESDIRECTORY
        MENUITEM "TTMPL/TTMPD僼傽僀儖偵曄姺偟偰曐懚(&O)",  ID_MODDING_EXPORTTOTTMP
