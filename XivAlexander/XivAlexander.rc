IDR_LOG_MENU MENU
BEGIN
    POPUP "ファイル(&F)"
    BEGIN
        MENUITEM "保存(&S)\tCtrl+S",              ID_FILE_SAVE
        MENUITEM "空にする(&E)\tCtrl+E",            ID_FILE_CLEAR
        MENUITEM SEPARATOR
        MENUITEM "閉じる(&W)\tCtrl+W",             ID_FILE_CLOSE
    END
    POPUP "表示(&V)"
    BEGIN
        MENUITEM "常に手前に表示(&T)\tCtrl+T",         ID_VIEW_ALWAYSONTOP
        MENUITEM SEPARATOR
        MENUITEM "ワードラップを使用(&W)\tCtrl+R",       ID_VIEW_USEWORDWRAP
        MENUITEM "等幅フォントを使用(&M)\tCtrl+M",       ID_VIEW_USEMONOSPACEDFONT
    END
END

IDR_CONFIG_EDITOR_MENU MENU
BEGIN
    POPUP "ファイル(&F)"
    BEGIN
        MENUITEM "保存(&S)\tCtrl+S",              ID_FILE_SAVE
        MENUITEM "元に戻す(&R)\tCtrl+R",            ID_FILE_REVERT
        MENUITEM SEPARATOR
        MENUITEM "閉じる(&W)\tCtrl+W",             ID_FILE_CLOSE
    END
    POPUP "表示(&V)"
    BEGIN
        MENUITEM "常に手前に表示(&T)\tCtrl+T",         ID_VIEW_ALWAYSONTOP
    END
END

IDR_TRAY_MENU MENU
BEGIN
    POPUP "ファイル(&F)"
    BEGIN
        MENUITEM "(Current Process Information)", ID_FILE_CURRENTINFO
        MENUITEM SEPARATOR
        MENUITEM "コントロールウィンドウの表示(&C)\tCtrl+(Alt+)W", ID_FILE_SHOWCONTROLWINDOW
        MENUITEM "ログウィンドウの表示(&L)\t(Ctrl+Alt+)L", ID_FILE_SHOWLOGGINGWINDOW
        MENUITEM "新規アップデートをチェック(&P)\tCtrl+(Alt+)U", ID_FILE_CHECKFORUPDATES
        MENUITEM "XivAlexanderを終了(&U)\tCtrl+(Alt+)Q", ID_FILE_UNLOADXIVALEXANDER
        MENUITEM SEPARATOR
        MENUITEM "ゲームを強制終了(&X)\tCtrl+Shift+Q",  ID_FILE_FORCEEXITGAME
    END
    POPUP "再起動(&R)"
    BEGIN
        MENUITEM "以下の設定で再起動(&R)\tCtrl+Shift+R", ID_RESTART_RESTART
        MENUITEM SEPARATOR
        MENUITEM "XivAlexanderを使用(&X)\t(Ctrl+Shift+)X", ID_RESTART_USEXIVALEXANDER
        MENUITEM "コマンドラインの難読化を使用(&P)\t(Ctrl+Shift+)P", ID_RESTART_USEPARAMETEROBFUSCATION
        MENUITEM "管理者として実行(&E)\t(Ctrl+Shift+)A", ID_RESTART_USEELEVATION
        MENUITEM SEPARATOR
        MENUITEM "言語：日本語(&J)",                  ID_RESTART_LANGUAGE_JAPANESE
        MENUITEM "言語：英語(&E)",                   ID_RESTART_LANGUAGE_ENGLISH
        MENUITEM "言語：ドイツ語(&D)",                 ID_RESTART_LANGUAGE_GERMAN
        MENUITEM "言語：フランス語(&F)",                ID_RESTART_LANGUAGE_FRENCH
        MENUITEM "言語：中国語(簡体字)(&C)",             ID_RESTART_LANGUAGE_SIMPLIFIEDCHINESE
        MENUITEM "言語：韓国語(&K)",                  ID_RESTART_LANGUAGE_KOREAN
        MENUITEM SEPARATOR
        MENUITEM "地域：日本(&1)",                   ID_RESTART_REGION_JAPAN
        MENUITEM "地域：北米(&2)",                   ID_RESTART_REGION_NORTH_AMERICA
        MENUITEM "地域：欧州(&3)",                   ID_RESTART_REGION_EUROPE
        MENUITEM SEPARATOR
        MENUITEM "言語の設定を保存(&L)",                ID_RESTART_LANGUAGE_REMEMBER, CHECKED
        MENUITEM "地域の設定を保存(&S)",                ID_RESTART_REGION_REMEMBER, CHECKED
    END
    POPUP "ネットワーク(&N)"
    BEGIN
        POPUP "遅延とタイミングの処理(&H)"
        BEGIN
            MENUITEM "有効化(&E)\t(Ctrl+Shift+)H",     ID_NETWORK_HIGHLATENCYMITIGATION_ENABLE
            MENUITEM SEPARATOR
            MENUITEM "モード&1：次のアクションの使用可能時刻からレイテンシを繰り上げる", ID_NETWORK_HIGHLATENCYMITIGATION_MODE_1
            MENUITEM "モード&2：サーバからの応答にかかる時間を{}usに固定", ID_NETWORK_HIGHLATENCYMITIGATION_MODE_2
            MENUITEM "モード&3：サーバーからの応答にかかる時間とレイテンシを補正", ID_NETWORK_HIGHLATENCYMITIGATION_MODE_3
            MENUITEM SEPARATOR
            MENUITEM "ログを有効にする(&L)\tCtrl+(Alt+)L",  ID_NETWORK_HIGHLATENCYMITIGATION_USELOGGING
            MENUITEM "作動のシミュレーション(ログに記録)(&P)\tCtrl+(Alt+)P", ID_NETWORK_HIGHLATENCYMITIGATION_PREVIEWMODE
        END
        MENUITEM SEPARATOR
        MENUITEM "IPCタイプファインダーを使用(&F)\t(Ctrl+Shift+)F", ID_NETWORK_USEIPCTYPEFINDER
        MENUITEM "すべてのIPCメッセージをログに記録(&I)\t(Ctrl+Shift+)M", ID_NETWORK_USEALLIPCMESSAGELOGGER
        MENUITEM SEPARATOR
        MENUITEM "パケット遅延の軽減(&R)\t(Ctrl+Shift+)F1", ID_NETWORK_REDUCEPACKETDELAY
        MENUITEM "すべての接続の処理を解除する(&E)\t(Ctrl+Shift+)F2", ID_NETWORK_RELEASEALLCONNECTIONS
        MENUITEM "すべての接続を強制に終了する(&S)\t(Ctrl+Shift+)F3", ID_NETWORK_RESETALLCONNECTIONS
        POPUP "トラブルシューティング(&T)"
        BEGIN
            MENUITEM "ループバックアドレスを処理(&L) (127.0.0.0/8)\t(Ctrl+Shift+)1", ID_NETWORK_TROUBLESHOOTREMOTEADDRESSES_TAKEOVERLOOPBACKADDRESSES
            MENUITEM "ローカルアドレスを処理(&P) (10.0.0.0/8, 169.254.0.0/16, 172.16.0.0/12, 192.168.0.0/24)\t(Ctrl+Shift+)2", ID_NETWORK_TROUBLESHOOTREMOTEADDRESSES_TAKEOVERPRIVATEADDRESSES
            MENUITEM "すべてのアドレスを処理(&A) (0.0.0.0/0)\t(Ctrl+Shift+)3", ID_NETWORK_TROUBLESHOOTREMOTEADDRESSES_TAKEOVERALLADDRESSES
            MENUITEM "すべてのポートを処理(&O)\t(Ctrl+Shift+)4", ID_NETWORK_TROUBLESHOOTREMOTEADDRESSES_TAKEOVERALLPORTS
        END
    END
    POPUP "MOD(&M)"
    BEGIN
        MENUITEM "有効化(&E)",                     ID_MODDING_ENABLE
        MENUITEM SEPARATOR
        POPUP "TexTools MODパック(&T)"
        BEGIN
            POPUP "(template entry to be inserted at bottom)"
            BEGIN
                MENUITEM "有効化(&E)",                     ID_MODDING_TTMP_ENTRY_ENABLE, CHECKED
                MENUITEM "削除(&D)",                      ID_MODDING_TTMP_ENTRY_DELETE
                MENUITEM SEPARATOR
                MENUITEM "再起動必要",                       ID_MODDING_TTMP_ENTRY_REQUIRESRESTART, INACTIVE
                MENUITEM "説明を表示(&S)",                   ID_MODDING_TTMP_ENTRY_SHOWDESCRIPTION
                MENUITEM SEPARATOR
            END
            MENUITEM "(インストール済みのMODパックなし)",         ID_MODDING_TTMP_NOENTRY, INACTIVE
            MENUITEM "(MOD機能がロードされてない)",            ID_MODDING_TTMP_NOTREADY, INACTIVE
            MENUITEM SEPARATOR
            MENUITEM "1次元でフォルダーを表示(&F)",            ID_MODDING_TTMP_FLATTENSUBDIRECTORYDISPLAY
            MENUITEM "1次元でフォルダーを表示の時、フォルダーの有・無効化設定を有効化(&T)", ID_MODDING_TTMP_USESUBDIRECTORYTOGGLINGONFLATTENEDVIEW
            MENUITEM "専用のメニューを表示(&M)",              ID_MODDING_TTMP_SHOWDEDICATEDMENU
            MENUITEM SEPARATOR
            MENUITEM "すべてを有効化(&E)",                 ID_MODDING_TTMP_ENABLEALL
            MENUITEM "すべてを無効化(&D)",                 ID_MODDING_TTMP_DISABLEALL
            MENUITEM SEPARATOR
            MENUITEM "インポート(&I)",                   ID_MODDING_TTMP_IMPORT
            MENUITEM "フォルダーを開ける(&O)",               ID_MODDING_TTMP_OPENDIRECTORY
            MENUITEM "すべてのMODパックを削除(&L)",           ID_MODDING_TTMP_REMOVEALL
            MENUITEM "再読み込み(&R)",                   ID_MODDING_TTMP_REFRESH
        END
        MENUITEM "置き換えファイルのフォルダーを開ける(&R)",      ID_MODDING_OPENREPLACEMENTFILEENTRIESDIRECTORY
        MENUITEM "TTMPL/TTMPDファイルに変換して保存(&O)",  ID_MODDING_EXPORTTOTTMP
        MENUITEM SEPARATOR
        MENUITEM "すべてのファイルのアクセスをログに記録(I)",      ID_MODDING_LOGALLFILEACCESS
        POPUP "声のミュート(&V)"
        BEGIN
            MENUITEM "戦闘(&B)",                      ID_MODDING_MUTEVOICE_BATTLE
            MENUITEM "CM(環境の声？)(&C)",               ID_MODDING_MUTEVOICE_CM
            MENUITEM "エモート(&E)",                    ID_MODDING_MUTEVOICE_EMOTE
            MENUITEM "戦闘中のNPCのセリフ(&D)",             ID_MODDING_MUTEVOICE_LINE
        END
        MENUITEM SEPARATOR
        MENUITEM "ゲームを再起動するまで適用されない場合があります。",   ID_MODDING_ANYTHINGBELOWHEREWILLBEAPPLIEDONRESTART, INACTIVE
    END
    POPUP "TTMP(&T)"
    BEGIN
        MENUITEM SEPARATOR
    END
    POPUP "設定(&C)"
    BEGIN
        MENUITEM "環境（ランタイム）設定(&R)\t(Ctrl+Alt+)R", ID_CONFIGURE_EDITRUNTIMECONFIGURATION
        MENUITEM "Opcodeの設定(&O)\t(Ctrl+Alt+)O", ID_CONFIGURE_EDITOPCODECONFIGURATION
        MENUITEM "Opcodeのアップデートを確認する(&U)",      ID_CONFIGURE_CHECKFORUPDATEDOPCODES
        MENUITEM "軌道のときに自動でOpcodeのアップデートを確認(&T)", ID_CONFIGURE_CHECKFORUPDATEDOPCODESONSTARTUP
        MENUITEM SEPARATOR
        POPUP "ゲームのバグのフィックス(&X)"
        BEGIN
            MENUITEM "(なし)",                        ID_CONFIGURE_GAMEFIX_EMPTY, INACTIVE
        END
        MENUITEM SEPARATOR
        MENUITEM "ゲームがCPUをできるだけ利用させる(&C)",      ID_CONFIGURE_USEMORECPUTIME
        MENUITEM "バックグラウンド時のフレームレートを制限(&B)", ID_CONFIGURE_BACKGROUND_FRAMERATE_LIMIT
        MENUITEM "FPSの固定(&F)",                  ID_CONFIGURE_LOCKFRAMERATE
        MENUITEM "リキャストとアニメーション待機時間とゲーム処理の同期化(&P)", ID_CONFIGURE_SYNCHRONIZEPROCESSING
        MENUITEM "ゲームウィンドウのタイトルにPIDを表示(&I)",    ID_CONFIGURE_ADDPIDTOGAMEWINDOWTITLE
        MENUITEM SEPARATOR
        POPUP "言語(&L) (Language/언어)"
        BEGIN
            MENUITEM "システム言語を使用(&S)\t",             ID_CONFIGURE_LANGUAGE_SYSTEMDEFAULT
            MENUITEM "英語(&E) (English)",            ID_CONFIGURE_LANGUAGE_ENGLISH
            MENUITEM "韓国語(&K) (언어)",                ID_CONFIGURE_LANGUAGE_KOREAN
            MENUITEM "日本語(&J)",                     ID_CONFIGURE_LANGUAGE_JAPANESE
        END
        POPUP "テーマ(&T)"
        BEGIN
            MENUITEM "システム(&S)",                    ID_CONFIGURE_THEME_SYSTEM
            MENUITEM "ライト(&L)",                     ID_CONFIGURE_THEME_LIGHT
            MENUITEM "ダーク(&D)",                     ID_CONFIGURE_THEME_DARK
        END
        MENUITEM SEPARATOR
        MENUITEM "設定のフォルダーを開ける(&D)",            ID_CONFIGURE_OPENCONFIGURATIONDIRECTORY
        MENUITEM "設定の再読み込み(&Z)\t(Ctrl+Shift+)F5", ID_CONFIGURE_RELOAD
    END
    POPUP "表示(&V)"
    BEGIN
        MENUITEM "常に手前に表示(&T)\tCtrl+T",         ID_VIEW_ALWAYSONTOP
        MENUITEM "ゲームウィンドウを常に手前に表示(&W)\tCtrl+Shift+T", ID_VIEW_ALWAYSONTOPGAME
        MENUITEM SEPARATOR
        MENUITEM "最小化の代わりにトレイに隠す(&H)",          ID_VIEW_HIDEONMINIMIZE
    END
    POPUP "ヘルプ(&H)"
    BEGIN
        MENUITEM "ヘルプページを表示(&W)",               ID_HELP_OPENHELPWEBPAGE
        MENUITEM SEPARATOR
        MENUITEM "ホームページを表示(&H)",               ID_HELP_OPENHOMEPAGE
    END
END


