/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_TRAY_MENU MENU
BEGIN
    POPUP "파일(&F)"
    BEGIN
        MENUITEM "(Current Process Information)", ID_FILE_CURRENTINFO
        MENUITEM SEPARATOR
        MENUITEM "관리 창 보이기(&C)\tCtrl+(Alt+)W",  ID_FILE_SHOWCONTROLWINDOW
        MENUITEM "로그 창 보이기(&L)\t(Ctrl+Alt+)L",  ID_FILE_SHOWLOGGINGWINDOW
        MENUITEM "업데이트 확인(&P)\tCtrl+(Alt+)U",   ID_FILE_CHECKFORUPDATES
        MENUITEM "XivAlexander 종료(&U)\tCtrl+(Alt+)Q", ID_FILE_UNLOADXIVALEXANDER
        MENUITEM SEPARATOR
        MENUITEM "게임 강제 종료(&X)\tCtrl+Shift+Q",  ID_FILE_FORCEEXITGAME
    END
    POPUP "재시작(&R)"
    BEGIN
        MENUITEM "아래 설정을 반영해 재시작하기(&R)\tCtrl+Shift+R", ID_RESTART_RESTART
        MENUITEM SEPARATOR
        MENUITEM "XivAlexander 사용(&X)\t(Ctrl+Shift+)X", ID_RESTART_USEXIVALEXANDER
        MENUITEM "명령줄 난독화 사용(&P)\t(Ctrl+Shift+)P", ID_RESTART_USEPARAMETEROBFUSCATION
        MENUITEM "관리자 권한으로 실행(&A)\t(Ctrl+Shift+)A", ID_RESTART_USEELEVATION
        MENUITEM SEPARATOR
        MENUITEM "언어: 일본어(&J)",                 ID_RESTART_LANGUAGE_JAPANESE
        MENUITEM "언어: 영어(&E)",                  ID_RESTART_LANGUAGE_ENGLISH
        MENUITEM "언어: 독일어(&D)",                 ID_RESTART_LANGUAGE_GERMAN
        MENUITEM "언어: 프랑스어(&F)",                ID_RESTART_LANGUAGE_FRENCH
        MENUITEM "언어: 중국어(간체)(&C)",             ID_RESTART_LANGUAGE_SIMPLIFIEDCHINESE
        MENUITEM "언어: 한국어(&K)",                 ID_RESTART_LANGUAGE_KOREAN
        MENUITEM SEPARATOR
        MENUITEM "지역: 일본(&1)",                  ID_RESTART_REGION_JAPAN
        MENUITEM "지역: 북미(&2)",                  ID_RESTART_REGION_NORTH_AMERICA
        MENUITEM "지역: 유럽(&3)",                  ID_RESTART_REGION_EUROPE
        MENUITEM SEPARATOR
        MENUITEM "언어 설정 기억(&L)",                ID_RESTART_LANGUAGE_REMEMBER, CHECKED
        MENUITEM "지역 설정 기억(&S)",                ID_RESTART_REGION_REMEMBER, CHECKED
    END
    POPUP "네트워크(&N)"
    BEGIN
        POPUP "지연 및 타이밍 도우미(&H)"
        BEGIN
            MENUITEM "사용(&E)\t(Ctrl+Shift+)H",      ID_NETWORK_HIGHLATENCYMITIGATION_ENABLE
            MENUITEM SEPARATOR
            MENUITEM "모드 &1: 지연 시간만큼 다음 기술 시전 가능 시각 앞당기기", ID_NETWORK_HIGHLATENCYMITIGATION_MODE_1
            MENUITEM "모드 &2: 서버 응답 시간을 {}us로 고정",   ID_NETWORK_HIGHLATENCYMITIGATION_MODE_2
            MENUITEM "모드 &3: 서버 응답 및 지연 시간 보정",     ID_NETWORK_HIGHLATENCYMITIGATION_MODE_3
            MENUITEM SEPARATOR
            MENUITEM "로그 사용(&L)\tCtrl+(Alt+)L",     ID_NETWORK_HIGHLATENCYMITIGATION_USELOGGING
            MENUITEM "모의 작동 (로그에서 미리 보기)(&P)\tCtrl+(Alt+)P", ID_NETWORK_HIGHLATENCYMITIGATION_PREVIEWMODE
        END
        MENUITEM SEPARATOR
        MENUITEM "IPC 검색 도우미 사용(&F)\t(Ctrl+Shift+)F", ID_NETWORK_USEIPCTYPEFINDER
        MENUITEM "모든 IPC 메시지 로그 사용(&I)\t(Ctrl+Shift+)M", ID_NETWORK_USEALLIPCMESSAGELOGGER
        MENUITEM SEPARATOR
        MENUITEM "패킷 딜레이 감소(&R)\t(Ctrl+Shift+)F1", ID_NETWORK_REDUCEPACKETDELAY
        MENUITEM "모든 연결 처리 해제하기(&E)\t(Ctrl+Shift+)F2", ID_NETWORK_RELEASEALLCONNECTIONS
        MENUITEM "모든 접속 강제 해제하기(&S)\t(Ctrl+Shift+)F3", ID_NETWORK_RESETALLCONNECTIONS
        POPUP "문제 해결(&T)"
        BEGIN
            MENUITEM "루프백 주소 처리(&L) (127.0.0.0/8)\t(Ctrl+Shift+)1", ID_NETWORK_TROUBLESHOOTREMOTEADDRESSES_TAKEOVERLOOPBACKADDRESSES
            MENUITEM "사설 주소 처리(&P) (10.0.0.0/8, 169.254.0.0/16, 172.16.0.0/12, 192.168.0.0/24)\t(Ctrl+Shift+)2", ID_NETWORK_TROUBLESHOOTREMOTEADDRESSES_TAKEOVERPRIVATEADDRESSES
            MENUITEM "모든 주소 처리(&A) (0.0.0.0/0)\t(Ctrl+Shift+)3", ID_NETWORK_TROUBLESHOOTREMOTEADDRESSES_TAKEOVERALLADDRESSES
            MENUITEM "모든 포트 처리(&O)\t(Ctrl+Shift+)4", ID_NETWORK_TROUBLESHOOTREMOTEADDRESSES_TAKEOVERALLPORTS
        END
    END
    POPUP "모딩(&M)"
    BEGIN
        MENUITEM "사용(&E)",                      ID_MODDING_ENABLE
        MENUITEM SEPARATOR
        MENUITEM "모든 파일 접근 기록하기(&I)",           ID_MODDING_LOGALLFILEACCESS
        MENUITEM "교체 파일 폴더 열기(&R)",             ID_MODDING_OPENREPLACEMENTFILEENTRIESDIRECTORY
        MENUITEM "TTMPL/TTMPD파일로 내보내기(&O)",     ID_MODDING_EXPORTTOTTMP
        MENUITEM SEPARATOR
        POPUP "TexTools 모드팩(&T)"
        BEGIN
            POPUP "(template entry to be inserted at bottom)"
            BEGIN
                MENUITEM "사용함(&E)",                     ID_MODDING_TTMP_ENTRY_ENABLE, CHECKED
                MENUITEM "제거(&D)",                      ID_MODDING_TTMP_ENTRY_DELETE
                MENUITEM SEPARATOR
                MENUITEM "재시작 필요",                      ID_MODDING_TTMP_ENTRY_REQUIRESRESTART, INACTIVE
                MENUITEM "설명 보기(&S)",                   ID_MODDING_TTMP_ENTRY_SHOWDESCRIPTION
                MENUITEM SEPARATOR
            END
            MENUITEM "(설치된 모드팩 없음 )",               ID_MODDING_TTMP_NOENTRY, INACTIVE
            MENUITEM "(모딩 기능 준비되지 않음)",             ID_MODDING_TTMP_NOTREADY, INACTIVE
            MENUITEM SEPARATOR
            MENUITEM "일차원으로 폴더 표시(&F)",             ID_MODDING_TTMP_FLATTENSUBDIRECTORYDISPLAY
            MENUITEM "일차원으로 폴더 표시 시 폴더 활성화 제어 사용(&T)", ID_MODDING_TTMP_USESUBDIRECTORYTOGGLINGONFLATTENEDVIEW
            MENUITEM "전용 메뉴 보이기(&M)",               ID_MODDING_TTMP_SHOWDEDICATEDMENU
            MENUITEM SEPARATOR
            MENUITEM "모두 활성화(&E)",                  ID_MODDING_TTMP_ENABLEALL
            MENUITEM "모두 비활성화(&D)",                 ID_MODDING_TTMP_DISABLEALL
            MENUITEM SEPARATOR
            MENUITEM "불러오기(&I)",                    ID_MODDING_TTMP_IMPORT
            MENUITEM "폴더 열기(&O)",                   ID_MODDING_TTMP_OPENDIRECTORY
            MENUITEM "모두 제거(&L)",                   ID_MODDING_TTMP_REMOVEALL
            MENUITEM "목록 다시 불러오기(&R)",              ID_MODDING_TTMP_REFRESH
        END
        POPUP "목소리 분류 음소거(&V)"
        BEGIN
            MENUITEM "전투(&B)",                      ID_MODDING_MUTEVOICE_BATTLE
            MENUITEM "CM(환경 속 목소리로 추측)(&C)",        ID_MODDING_MUTEVOICE_CM
            MENUITEM "감정 표현(&E)",                   ID_MODDING_MUTEVOICE_EMOTE
            MENUITEM "전투 중 NPC 대사(&D)",             ID_MODDING_MUTEVOICE_LINE
        END
        MENUITEM SEPARATOR
        MENUITEM "게임 재시작까지 변경 사항이 반영되지 않을 수도 있습니다.", ID_MODDING_ANYTHINGBELOWHEREWILLBEAPPLIEDONRESTART, INACTIVE
    END
    POPUP "TTMP(&T)"
    BEGIN
        MENUITEM SEPARATOR
    END
    POPUP "설정(&C)"
    BEGIN
        MENUITEM "런타임(프로그램) 설정 변경(&R)\t(Ctrl+Alt+)R", ID_CONFIGURE_EDITRUNTIMECONFIGURATION
        MENUITEM "옵코드 설정 변경(&O)\t(Ctrl+Alt+)O", ID_CONFIGURE_EDITOPCODECONFIGURATION
        MENUITEM "옵코드 업데이트 확인하기(&U)",           ID_CONFIGURE_CHECKFORUPDATEDOPCODES
        MENUITEM "프로그램 시작 시 자동으로 옵코드 업데이트 확인(&T)", ID_CONFIGURE_CHECKFORUPDATEDOPCODESONSTARTUP
        MENUITEM SEPARATOR
        POPUP "게임 버그 수정(&X)"
        BEGIN
            MENUITEM "(수정 가능한 버그 없음)",              ID_CONFIGURE_GAMEFIX_EMPTY, INACTIVE
        END
        MENUITEM SEPARATOR
        MENUITEM "게임이 가능한 만큼 CPU를 쓰도록 만들기(&C)", ID_CONFIGURE_USEMORECPUTIME
        MENUITEM "백그라운드 시 프레임 레이트 제한(&B)", ID_CONFIGURE_BACKGROUND_FRAMERATE_LIMIT
        MENUITEM "FPS 고정(&F)",                  ID_CONFIGURE_LOCKFRAMERATE
        MENUITEM "재사용 대기 시간 및 애니메이션 시간에 게임 처리를 동기화하기(&P)", ID_CONFIGURE_SYNCHRONIZEPROCESSING
        MENUITEM "게임 창 제목에 PID 표시(&I)",         ID_CONFIGURE_ADDPIDTOGAMEWINDOWTITLE
        MENUITEM SEPARATOR
        POPUP "언어(&L) (Language/言語)"
        BEGIN
            MENUITEM "시스템 기본(&S)",                  ID_CONFIGURE_LANGUAGE_SYSTEMDEFAULT
            MENUITEM SEPARATOR
            MENUITEM "영어(&E) (English)",            ID_CONFIGURE_LANGUAGE_ENGLISH
            MENUITEM "한국어(&K)",                     ID_CONFIGURE_LANGUAGE_KOREAN
            MENUITEM "일본어(&J) (日本語)",               ID_CONFIGURE_LANGUAGE_JAPANESE
        END
        POPUP "테마(&T)"
        BEGIN
            MENUITEM "시스템(&S)",                     ID_CONFIGURE_THEME_SYSTEM
            MENUITEM "라이트(&L)",                     ID_CONFIGURE_THEME_LIGHT
            MENUITEM "다크(&D)",                      ID_CONFIGURE_THEME_DARK
        END
        MENUITEM SEPARATOR
        MENUITEM "설정값 저장 폴더 열기(&D)",            ID_CONFIGURE_OPENCONFIGURATIONDIRECTORY
        MENUITEM "설정 다시 불러오기(&Z)\t(Ctrl+Shift+)F5", ID_CONFIGURE_RELOAD
    END
    POPUP "보기(&V)"
    BEGIN
        MENUITEM "항상 위에 표시(&T)\tCtrl+T",        ID_VIEW_ALWAYSONTOP
        MENUITEM "게임을 항상 위에 표시(&W)\tCtrl+Shift+T", ID_VIEW_ALWAYSONTOPGAME
        MENUITEM SEPARATOR
        MENUITEM "최소화 시 숨김(&H)",                ID_VIEW_HIDEONMINIMIZE
    END
    POPUP "도움말(&H)"
    BEGIN
        MENUITEM "도움말 웹페이지 표시(&W)",             ID_HELP_OPENHELPWEBPAGE
        MENUITEM SEPARATOR
        MENUITEM "홈페이지 표시(&H)",                 ID_HELP_OPENHOMEPAGE
    END
END

