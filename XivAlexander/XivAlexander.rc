/////////////////////////////////////////////////////////////////////////////
//
// String Table
//

STRINGTABLE
BEGIN
    IDS_ERROR_INCONSISTENT_FILES "Inconsistent component file versions."
    IDS_ERROR_MISSING_FILES "Component files not found."
